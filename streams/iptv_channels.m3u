import os

def generate_m3u(directory):
    # Βεβαιώσου ότι ο φάκελος "streams" υπάρχει
    output_dir = 'streams'
    if not os.path.exists(output_dir):
        os.makedirs(output_dir)

    output_file = os.path.join(output_dir, 'iptv_channels.m3u')
    
    # Γράψε τα δεδομένα στο αρχείο m3u
    with open(output_file, 'w') as f_out:
        f_out.write("#EXTM3U\n")
        # Παράδειγμα για προσθήκη στοιχείων
        # f_out.write("#EXTINF:-1, Channel Name\n")
        # f_out.write("http://stream-url.com\n")
